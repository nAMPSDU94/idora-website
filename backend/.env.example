# Database — SQLite for dev, switch to PostgreSQL for prod
DATABASE_URL="file:./dev.db"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@localhost:5432/idora"

# Server
PORT=3001
NODE_ENV=development

# Admin panel password
ADMIN_SECRET=idora-admin-2024

# Email (configure with your SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email addresses
EMAIL_FROM=IDORA Magazines <hello@idora-mag.com>
EMAIL_ADMIN=hello@idora-mag.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500
